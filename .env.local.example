# Copy to .env.local and fill in values. Never commit .env.local.

# =============================================================================
# Supabase (required for the app)
# Project: Dashboard → Settings → API (https://supabase.com/dashboard/project/_/settings/api)
# =============================================================================
# Public: used by the browser + server Supabase clients (anon key respects RLS).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only: bypasses RLS — use only in API routes / server actions that must act as admin.
# Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT signing secret (Dashboard → Settings → API → JWT Settings).
# Not read by current app code; keep for CLI tools, custom JWT verification, or future middleware.
SUPABASE_JWT_SECRET=your-jwt-secret

# Optional — Supabase CLI (e.g. npx supabase db push) without interactive login:
# Dashboard → Account → Access Tokens → https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=

# Optional — Postgres URI (Dashboard → Settings → Database → Connection string, URI).
# For psql, supabase db query --db-url, or ORMs. Use the direct or pooler URL you prefer.
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@db.[ref].supabase.co:5432/postgres

# =============================================================================
# Site + other integrations
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

YOUTUBE_API_KEY=your-youtube-data-api-v3-key
DEEPL_API_KEY=your-deepl-key
TRANSLATE_API_SECRET=your-translate-secret-32-chars-min
TRANSCRIPT_API_SECRET=your-transcript-secret-32-chars-min
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key
